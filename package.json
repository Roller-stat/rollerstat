{
  "name": "rollerstat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "cd apps/web && next dev",
    "dev:mobile": "cd apps/mobile && npm run start",
    "dev:mobile:android": "cd apps/mobile && npm run android",
    "dev:admin": "node scripts/dev-admin.mjs",
    "build": "npm run build:web && npm run build:admin",
    "build:web": "cd apps/web && next build && next-sitemap",
    "build:admin": "cd apps/admin && next build",
    "start": "npm run start:web",
    "start:web": "cd apps/web && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "start:admin": "cd apps/admin && next start -H 0.0.0.0 -p ${ADMIN_PORT:-3001}",
    "lint": "npm run lint:web && npm run lint:admin",
    "lint:web": "cd apps/web && eslint .",
    "lint:admin": "cd apps/admin && eslint .",
    "content:build": "cd apps/web && npx contentlayer2 build",
    "retention:run": "node scripts/run-retention-cleanup.mjs"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.2.2",
    "@formatjs/intl": "^3.1.6",
    "@getbrevo/brevo": "^3.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fs-extra": "^11.3.2",
    "lucide-react": "^0.542.0",
    "motion": "^12.23.22",
    "next": "15.5.9",
    "next-auth": "^5.0.0-beta.29",
    "next-intl": "^4.3.6",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.10.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "contentlayer2": "^0.5.8",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "next-contentlayer2": "^0.5.8",
    "open": "^10.2.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5"
  }
}
